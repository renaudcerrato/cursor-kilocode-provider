{
  "name": "cursor-kilocode-provider",
  "version": "0.1.2",
  "description": "Use Cursor subscription models from Kilo Code via Cursor's Connect-RPC agent protocol",
  "type": "module",
  "license": "MIT",
  "author": "renaudcerrato",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/renaudcerrato/cursor-kilocode-provider.git"
  },
  "bugs": {
    "url": "https://github.com/renaudcerrato/cursor-kilocode-provider/issues"
  },
  "homepage": "https://github.com/renaudcerrato/cursor-kilocode-provider#readme",
  "keywords": [
    "kilo",
    "kilocode",
    "cursor",
    "ai-sdk",
    "provider",
    "plugin"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@ai-sdk/provider": "3.0.8",
    "protobufjs": "^7.4.0"
  },
  "peerDependencies": {
    "@kilocode/plugin": "^7.4.7"
  },
  "devDependencies": {
    "@kilocode/plugin": "^7.4.7",
    "@tsconfig/node22": "^22.0.1",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
